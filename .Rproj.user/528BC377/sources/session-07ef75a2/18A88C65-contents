```

# Make features
```{r}
full_data <- full_data |> 
  mutate( 
    mean = mean, 
    sd = sd, 
    ske = skewness, 
    kur = kurtosis)
```

# Break into train, test, and validation sets 
```{r}
library(tidymodels)
set.seed(88)
full_data_split <- initial_validation_split(full_data, prop = c(0.75,0.125))
full_train <- training(full_data_split)
full_test <- testing(full_data_split)
full_vals <- validation(full_data_split)
```
# Normalize before PCA
```{r}
library(bestNormalize)
train_rec <- recipe(byd ~ ., data = full_train) |> 
  step_zv(all_numeric_predictors())  |>  
  step_impute_median(all_numeric_predictors())  |>  
  step_orderNorm(all_numeric_predictors()) |> 
  step_normalize(all_numeric_predictors()) |>  
  step_pca(all_numeric_predictors(), num_comp = tune())
```

# Set the linear model up 
```{r}
linear_model <- linear_reg()  |>  
  set_engine("lm")
wf <- workflow()  |>  
  add_recipe(train_rec) |> 
  add_model(linear_model)
```
#CV inside training sets
```{r}
set.seed(111)
folds <- vfold_cv(full_train, v = 10)
tune_res <- tune_grid(
 wf, 
 resamples = folds, 
 grid = 10
)
best_pca <- select_best(tune_res, metric = "rmse")
final_workflow <- finalize_workflow(wf, best_pca)
```
# Fit on the data
```{r}
final_fit <- fit(final_workflow, data = full_train)
vals_pred <- predict(final_fit, new_data = full_vals) |> 
             bind_cols(full_vals |> 
             select(byd)
             )
metrics(vals_pred, truth = byd, estimate = .pred)
```
# Evaluate on test set 
```{r}
test_pred <- predict(final_fit, new_data = full_test) |> 
             bind_cols(full_test |> 
             select(byd)
             )
test_metric <- metrics(test_pred, truth = byd, estimate = .pred)
print(test_metric)
```

